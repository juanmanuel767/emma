# ════════════════════════════════════════════════════════════════════════════
#  EMMA — Configuración
#  © 2026 Juan Manuel Peralta Chacón. Todos los derechos reservados.
# ════════════════════════════════════════════════════════════════════════════
#
#  🟢 EMMA FUNCIONA SIN NINGUNA CLAVE.
#  Por defecto usa OLLAMA (modelos de IA locales y gratuitos que corren en tu
#  propia máquina). El instalador (install.sh) lo instala todo por ti.
#  Solo copia este archivo a ".env" y arranca — no necesitas configurar nada.
#
#  Las claves de abajo son TODAS OPCIONALES: solo añádelas si quieres más
#  velocidad o capacidades extra (Telegram, correo, etc.).
# ════════════════════════════════════════════════════════════════════════════

# ─── 🧠 Cerebro por defecto: Ollama (local, gratis, SIN claves) ───────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:latest

# ─── ⚡ Modelos en la nube (OPCIONALES — más rápidos; planes gratuitos) ────────
# Groq:       https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=qwen/qwen3-32b
# OpenRouter: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODELS=qwen/qwen3-coder:free,nvidia/nemotron-3-ultra-550b-a55b:free
# OpenCode Zen — modelos gratis ($0). Consigue la clave en https://opencode.ai/zen
OPENCODE_API_KEY=
OPENCODE_MODEL=deepseek-v4-flash-free
# Cadena de modelos gratis de Zen (failover). Todos con soporte de tools.
OPENCODE_MODELS=deepseek-v4-flash-free,north-mini-code-free,mimo-v2.5-free,nemotron-3-ultra-free
# Claude (de pago, solo para tareas difíciles): https://console.anthropic.com
ANTHROPIC_API_KEY=
# OpenAI (opcional):
OPENAI_API_KEY=

# ─── 🔌 Integraciones (OPCIONALES) ────────────────────────────────────────────
# Telegram (bot): https://t.me/BotFather
TELEGRAM_BOT_TOKEN=
# Correo (App Password de Gmail): https://myaccount.google.com/apppasswords
EMAIL_USER=
EMAIL_PASSWORD=
# Memoria semántica de largo plazo (embeddings): https://dash.voyageai.com
VOYAGE_API_KEY=
# GitHub (token): https://github.com/settings/tokens
GH_TOKEN=

# ─── 🗄️ Infraestructura (Postgres + Redis vía docker-compose) ─────────────────
DATABASE_URL=postgresql://emma:emma@localhost:5432/emma
POSTGRES_USER=emma
POSTGRES_PASSWORD=emma
POSTGRES_DB=emma
REDIS_URL=redis://localhost:6379

# ─── 🔐 Seguridad (el instalador genera un valor aleatorio) ───────────────────
JWT_SECRET=change-me-in-production-min-32-chars

# ─── ⚙️ Servicios internos ────────────────────────────────────────────────────
GATEWAY_PORT=3000
AGENT_PORT=3001
AGENT_SERVICE_URL=http://localhost:3001
NODE_ENV=development
LOG_LEVEL=info
