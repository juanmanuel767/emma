# ─── Claude ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Embeddings (Voyage AI) ───────────────────────────────────────────────────
VOYAGE_API_KEY=pa-...

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://emma:emma@localhost:5432/emma
POSTGRES_USER=emma
POSTGRES_PASSWORD=emma
POSTGRES_DB=emma

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-min-32-chars

# ─── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ─── Servicios internos ───────────────────────────────────────────────────────
GATEWAY_PORT=3000
AGENT_PORT=3001
AGENT_SERVICE_URL=http://localhost:3001

# ─── Entorno ──────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# OpenRouter — modelos gratis con fallback automático
OPENROUTER_API_KEY=
OPENROUTER_MODELS=qwen/qwen3-coder:free,nvidia/nemotron-3-ultra-550b-a55b:free,nvidia/nemotron-3-super-120b-a12b:free

# OpenCode Zen — modelos free verificados (https://opencode.ai/auth)
OPENCODE_API_KEY=
OPENCODE_MODEL=big-pickle
